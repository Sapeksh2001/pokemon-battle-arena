# ============================================
# POKÉMON BATTLE ARENA - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ── SERVER CONFIGURATION ─────────────────────
PORT=3001
NODE_ENV=development

# ── FRONTEND URL (for CORS) ──────────────────
# Local development:
FRONTEND_URL=http://localhost:3000

# Production (UPDATE after Vercel deployment):
# FRONTEND_URL=https://your-app.vercel.app

# ── DATABASE (Optional - if using PostgreSQL) ─
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ── RENDER DEPLOYMENT NOTES ──────────────────
# When deploying to Render:
# 1. PORT is automatically set by Render (don't change)
# 2. Set FRONTEND_URL to your Vercel domain
# 3. Set NODE_ENV to "production"
# 
# In Render dashboard:
# Environment → Add Environment Variable
# Key: FRONTEND_URL
# Value: https://your-app.vercel.app
